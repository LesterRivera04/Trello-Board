@model UserStoryViewModel

<h2 class="edit-title mb-5 mt-3">Editar Historia de usuario</h2>

<form asp-action="Edit" method="post" class="form-labels-Lester">
    <input type="hidden" name="id" value="@Model.Id" />
    <div class="mb-3">
        <label asp-for="Titulo" class="form-label">Título:</label>
        <input asp-for="Titulo" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Descripcion" class="form-label">Descripción:</label>
        <textarea asp-for="Descripcion" class="form-control" rows="4"></textarea>
    </div>
    <div class="mb-3">
        <label asp-for="Acceptance_Criteria" class="form-label">Criterios de aceptación:</label>
        <textarea asp-for="Acceptance_Criteria" class="form-control" rows="3"></textarea>
    </div>
    <div class="mb-3">
        <label asp-for="Estimacion" class="form-label">Estimación (en puntos):</label>
        <input asp-for="Estimacion" class="form-control" type="number" min="1" />
    </div>
    <div class="mb-3">
        <label asp-for="AsignadoA" class="form-label">Asignado a:</label>
        <select asp-for="AsignadoA" class="form-select">
            <option value="">Seleccionar usuario</option>
            @foreach (var usuario in ViewBag.Usuarios)
            {
                <option value="@usuario.Id">@usuario.Nombre @usuario.Apellidos</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="Estado" class="form-label">Estado:</label>
        <select asp-for="Estado" class="form-select">
            <option value="Backlog" selected="@(Model.Estado == "Backlog")">Backlog</option>
            <option value="ToDo" selected="@(Model.Estado == "ToDo")">To Do</option>
            <option value="InProgress" selected="@(Model.Estado == "InProgress")">In Progress</option>
            <option value="Done" selected="@(Model.Estado == "Done")">Done</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Guardar cambios</button>
    <a asp-controller="Board" asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>